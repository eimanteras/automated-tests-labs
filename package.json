{
  "name": "automated-tests-labs",
  "version": "1.0.0",
  "description": "Labs for Design and Development of Automated Tests (Playwright + TypeScript)",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:all": "playwright test",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "api:test": "newman run postman/gmail-automation.postman_collection.json -e postman/gmail-automation.postman_environment.json",
    "api:test:html": "newman run postman/gmail-automation.postman_collection.json -e postman/gmail-automation.postman_environment.json --reporters cli,htmlextra"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1"
  }
}
