              "});",
              "",
              "pm.test(\"delete label response is empty\", function () {",
              "  pm.expect(pm.response.text()).to.eql('');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "8. Postcondition - Move Sent Email To Trash",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{gmail_base_url}}/users/me/messages/{{sent_message_id}}/trash",
          "host": [
            "{{gmail_base_url}}"
          ],
          "path": [
            "users",
            "me",
            "messages",
            "{{sent_message_id}}",
            "trash"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test(\"message moved to trash\", function () {",
              "  pm.expect(json.id).to.eql(pm.environment.get('sent_message_id'));",
              "  pm.expect(json.labelIds).to.include('TRASH');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "gmail_base_url",
      "value": "https://gmail.googleapis.com/gmail/v1"
    }
  ]
}
